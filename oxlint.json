{
  "$schema": "./node_modules/oxlint/configuration_schema.json",
  "plugins": ["import"],
  "ignorePatterns": ["dist/**", "coverage/**", ".turbo/**", "node_modules/**"],
  "rules": {
    "no-console": "warn",
    "no-debugger": "error",
    "no-unused-vars": "warn",
    "import/no-duplicates": "error"
  }
}
