# Copy this file to secret.env at the repository root and fill in your values.
# secret.env is gitignored and will not be committed.

# --- OAuth (recommended for stdio / MCP client development) ---
# Create an OAuth client at https://app.transcend.com/admin/oauth-clients
# Register redirect URI: http://127.0.0.1:your-client-redirect-port/callback (use 127.0.0.1, not localhost)
TRANSCEND_OAUTH_CLIENT_ID=
TRANSCEND_OAUTH_CLIENT_SECRET=
TRANSCEND_OAUTH_REDIRECT_PORT=your-client-redirect-port
# TRANSCEND_OAUTH_REDIRECT_HOST=127.0.0.1

# --- API key (alternative for stdio, or for HTTP transport) ---
# When set alongside OAuth client ID, API key takes precedence and disables OAuth.
TRANSCEND_API_KEY=

# Optional overrides (omit to use production Transcend defaults)
# TRANSCEND_API_URL=https://api.transcend.io
# SOMBRA_URL=https://multi-tenant.sombra.transcend.io
# TRANSCEND_DASHBOARD_URL=https://app.transcend.io
# TRANSCEND_OAUTH_ISSUER=https://api.transcend.io  # test-only; production auto-detects region
