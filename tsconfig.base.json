{
  "$schema": "https://json.schemastore.org/tsconfig",
  "files": ["./types/svg.d.ts"],
  "compilerOptions": {
    "target": "ES2022",
    "lib": ["ES2022"],
    "module": "NodeNext",
    "moduleResolution": "NodeNext",
    "strict": true,
    "isolatedModules": true,
    "isolatedDeclarations": true,
    "declaration": true,
    "declarationMap": true,
    "sourceMap": true,
    "composite": true,
    "incremental": true,
    "skipLibCheck": true,
    "noUncheckedIndexedAccess": true,
    "verbatimModuleSyntax": true,
    "resolveJsonModule": true,
    "customConditions": ["@transcend-io/source"],
    "paths": {
      "@tools/assets/*": ["./assets/*"]
    }
  }
}
