    "@types/lodash-es": "^4.17.12",
    "@types/node": "catalog:",
    "@types/semver": "catalog:",
    "@types/yargs-parser": "^21.0.0",
    "date-fns": "^4.1.0",
    "doctoc": "^2.2.1",
    "fdir": "^6.4.6",
    "publint": "catalog:",
    "tsdown": "catalog:",
