    "@transcend-io/sdk": "workspace:*",
    "@transcend-io/secret-value": "^1.2.3",
    "@transcend-io/type-utils": "workspace:*",
    "@transcend-io/utils": "workspace:*",
    "JSONStream": "^1.3.5",
    "bluebird": "^3.7.2",
    "cli-progress": "^3.11.2",
    "colors": "^1.4.0",
    "csv-parse": "^5.6.0",
    "fast-csv": "^4.3.6",
    "fast-glob": "^3.2.12",
    "fp-ts": "^2.16.1",
    "fuzzysearch": "^1.0.3",
    "global-agent": "^3.0.0",
    "got": "^11.8.5",
    "graphql": "^16.6.0",
    "graphql-request": "^5.0.0",
    "inquirer": "^8.0.0",
    "inquirer-autocomplete-prompt": "=1.3.0",
    "io-ts": "^2.2.21",
    "io-ts-types": "^0.5.16",
    "js-yaml": "^4.1.0",
    "jsonwebtoken": "^9.0.2",
    "lodash-es": "^4.17.21",
    "monocle-ts": "^2.3.13",
    "ms": "3.0.0-canary.202508261828",
    "newtype-ts": "^0.3.5",
    "query-string": "=7.0.0",
    "semver": "catalog:",
    "undici": "^6.24.0",
    "yargs-parser": "^21.1.1"
  },
  "devDependencies": {
    "@arethetypeswrong/cli": "catalog:",
    "@types/JSONStream": "npm:@types/jsonstream@^0.8.33",
    "@types/bluebird": "^3.5.38",
    "@types/cli-progress": "^3.11.0",
    "@types/colors": "^1.2.1",
    "@types/fuzzysearch": "^1.0.0",
    "@types/global-agent": "^2.1.1",
    "@types/inquirer": "^8.0.0",
    "@types/inquirer-autocomplete-prompt": "^3.0.0",
    "@types/js-yaml": "^4.0.5",
    "@types/json-schema": "catalog:",
