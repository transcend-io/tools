{
  "editor.defaultFormatter": "oxc.oxc-vscode",
  "editor.formatOnSave": true,
  "editor.formatOnSaveMode": "file",
  "oxc.fmt.configPath": ".oxfmtrc.jsonc",
  "oxc.enable": true,
  /**
   * Since we use oxc for linting and oxfmt for formatting, we disable ESLint and Prettier extensions.
   * You should disable the extensions for this repository:
   *   - Right-click the extension in the Extensions view and select "Disable (Workspace)".
   * If formatOnSave is not working, delete any "defaultFormatter" selections in your user settings.json like this:
   *   ```json
   *   "[typescript]": {
   *     "editor.defaultFormatter": "esbenp.prettier-vscode",
   *   }
   *   ```
   */
  "prettier.enable": false,
  "eslint.enable": false,
  "typescript.tsdk": "node_modules/typescript/lib"
}
